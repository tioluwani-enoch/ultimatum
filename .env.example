# Frontend chat switch.
# Keep this false/blank if you want the built-in local fallback chat.
VITE_USE_CLAUDE_CHAT=true
VITE_CHAT_API_URL=/api/chat

# Server-only Claude settings.
# Never expose ANTHROPIC_API_KEY in frontend code or with a VITE_ prefix.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
